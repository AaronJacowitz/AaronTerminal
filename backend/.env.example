POLYGON_API_KEY=your_polygon_api_key_here
RENTCAST_API_KEY=your_rentcast_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# Optional
OPENAI_MODEL=gpt-4.1-mini
# Comma-separated tickers used for "top performers" snapshots
AGENT_UNIVERSE_TICKERS=SPY,QQQ,AAPL,MSFT,NVDA,AMZN,META,GOOGL,TSLA,AVGO,AMD,NFLX,JPM,XOM,CVX,UNH,LLY,COST,WMT,BRK-B

# Auth (change this in production!)
JWT_SECRET=dev-insecure-change-me

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aaronterminal
