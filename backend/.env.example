# ── AI Agent (Groq is free — recommended) ──────────────────────────────────────
# Sign up at console.groq.com (no credit card required)
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the default Groq model
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI fallback (only used if GROQ_API_KEY is not set)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Comma-separated tickers used for "top performers" market snapshots
AGENT_UNIVERSE_TICKERS=SPY,QQQ,AAPL,MSFT,NVDA,AMZN,META,GOOGL,TSLA,AVGO,AMD,NFLX,JPM,XOM,CVX,UNH,LLY,COST,WMT,BRK-B

# ── Market data ─────────────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here

# ── Real estate (set RENTCAST_MOCK=false + add key to use live data) ────────────
RENTCAST_API_KEY=your_rentcast_api_key_here
RENTCAST_MOCK=true

# ── Auth (change JWT_SECRET before deploying!) ──────────────────────────────────
JWT_SECRET=dev-insecure-change-me

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aaronterminal
